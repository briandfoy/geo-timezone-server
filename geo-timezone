sub timezones ($lat, $long, $date ) {
	state $file_base = '/Users/brian/.ebird-perl/timezones-1970/combined-shapefile-1970';
	state $finder = do {
		require Geo::Location::TimeZoneFinder;
		Geo::Location::TimeZoneFinder->new( file_base => $ENV{'TIMEZONES_1970'} // $default_file_base );
		};

	my %hash;

	$hash{'geo'}->@{qw(latitude longitude)} = ($lat, $long);
	$hash{'input_date'} = $date;

	push $hash{'errors'}->@*, "Latitude <$lat> out-of-range"   if abs($lat)  >  90;
	push $hash{'errors'}->@*, "Longitude <$long> out-of-range" if abs($long) > 180;

	try {
		$hash{'names'} = [ $finder->time_zones_at(
			latitude  => $lat,
			longitude => $long,
			) ];
		my $tz = timezone($hash{'names'}[0]);
		$hash{'epoch'} = str2time($hash{'input_date'}, format => 'DateTime', timezone => $tz);
		@hash{qw(offset dst abbr)} = $tz->type_info_for_local($hash{'epoch'}, gap_policy => 'std');
		$hash{'dst'} = $hash{'dst'} ? true : false;
		$hash{'offset'} = sprintf '%+03d:%02d', $hash{'offset'} / 3600, $hash{'offset'} % 60;
		$hash{'date'} = time2str($hash{'epoch'}, timezone => $tz);
		}
	catch ($e) {
		push $hash{'errors'}->@*, $e;
		}

	\%hash;
	}
